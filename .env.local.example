# ⚠️  Copiez ce fichier en .env.local et remplissez les valeurs

# Auth.js — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=REMPLACER_PAR_CLE_ALEATOIRE

# Google OAuth (optionnel pour dev local, mettre des valeurs vides)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (mettre une fausse valeur pour le dev, les emails ne seront pas envoyés)
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=contact@linsaem.fr
RESEND_TO_EMAIL=contact@linsaem.fr

# Stripe (clés de TEST depuis dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_REMPLACER
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_STARTER_PRICE_ID=price_placeholder
STRIPE_PRO_PRICE_ID=price_placeholder
STRIPE_BUSINESS_PRICE_ID=price_placeholder

# Vercel Postgres (pour le dev local, installer postgres local ou utiliser Vercel dev)
POSTGRES_URL=postgresql://username:password@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# URL de l'app
NEXT_PUBLIC_APP_URL=http://localhost:3000
